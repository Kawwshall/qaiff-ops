{
  "name": "FF Attendance",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "autoname": "format:ATT-{####}",
  "title_field": "operator_name",
  "search_fields": "operator_name,project",
  "fields": [
    {"fieldname": "project", "fieldtype": "Link", "label": "Project", "options": "FF Project", "reqd": 1, "in_list_view": 1},
    {"fieldname": "operator", "fieldtype": "Link", "label": "Operator", "options": "Operator", "reqd": 1, "in_list_view": 1},
    {"fieldname": "operator_name", "fieldtype": "Data", "label": "Name", "fetch_from": "operator.full_name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "date", "fieldtype": "Date", "label": "Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Present\nAbsent\nHalf Day", "default": "Present", "reqd": 1, "in_list_view": 1},
    {"fieldname": "daily_rate", "fieldtype": "Currency", "label": "Daily Rate", "in_list_view": 1},
    {"fieldname": "marked_by", "fieldtype": "Data", "label": "Marked By", "read_only": 1}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "FF Chief", "read": 1, "write": 1, "create": 1, "delete": 0, "report": 1},
    {"role": "FF Operator", "read": 1, "write": 0, "create": 0, "delete": 0}
  ]
}
