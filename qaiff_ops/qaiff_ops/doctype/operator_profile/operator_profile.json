{
  "name": "Operator Profile",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "fields": [
    {"fieldname": "full_name", "fieldtype": "Data", "label": "Full Name", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "phone", "fieldtype": "Data", "label": "WhatsApp Number", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "aadhar_number", "fieldtype": "Data", "label": "Aadhar Number", "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Active\nInactive\nBlacklisted", "default": "Active", "in_list_view": 1},
    {"fieldname": "section_contact", "fieldtype": "Section Break", "label": "Contact & Social"},
    {"fieldname": "email", "fieldtype": "Data", "label": "Email ID", "options": "Email"},
    {"fieldname": "telegram_id", "fieldtype": "Data", "label": "Telegram ID"},
    {"fieldname": "discord_id", "fieldtype": "Data", "label": "Discord ID"},
    {"fieldname": "twitter_id", "fieldtype": "Data", "label": "X (Twitter) ID"},
    {"fieldname": "section_personal", "fieldtype": "Section Break", "label": "Personal Info"},
    {"fieldname": "occupation", "fieldtype": "Data", "label": "Occupation / Organization"},
    {"fieldname": "languages", "fieldtype": "Small Text", "label": "Languages"},
    {"fieldname": "health_preferences", "fieldtype": "Small Text", "label": "Health / Food Preferences"},
    {"fieldname": "referred_by", "fieldtype": "Data", "label": "Referred By"},
    {"fieldname": "section_payment", "fieldtype": "Section Break", "label": "Payment Details"},
    {"fieldname": "upi_id", "fieldtype": "Data", "label": "UPI ID"},
    {"fieldname": "bank_account_number", "fieldtype": "Data", "label": "Bank Account Number"},
    {"fieldname": "ifsc_code", "fieldtype": "Data", "label": "IFSC Code"},
    {"fieldname": "branch_name", "fieldtype": "Data", "label": "Branch Name"},
    {"fieldname": "bank_name", "fieldtype": "Data", "label": "Bank Name"},
    {"fieldname": "section_docs", "fieldtype": "Section Break", "label": "Documents"},
    {"fieldname": "aadhar_document_link", "fieldtype": "Data", "label": "Aadhar Front & Back (Drive Link)"},
    {"fieldname": "intro_video_link", "fieldtype": "Data", "label": "Intro Video (Drive Link)"}
  ],
  "title_field": "full_name",
  "search_fields": "full_name,phone,aadhar_number",
  "autoname": "field:full_name",
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "All", "read": 1}
  ]
}
