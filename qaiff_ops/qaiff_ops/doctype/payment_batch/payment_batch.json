{
  "name": "Payment Batch",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "fields": [
    {"fieldname": "batch_name", "fieldtype": "Data", "label": "Batch Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "project", "fieldtype": "Link", "label": "Project", "options": "QAIFF Project", "reqd": 1, "in_list_view": 1},
    {"fieldname": "batch_date", "fieldtype": "Date", "label": "Batch Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nApproved\nPaid\nCancelled", "default": "Draft", "in_list_view": 1},
    {"fieldname": "section_summary", "fieldtype": "Section Break", "label": "Summary"},
    {"fieldname": "total_operators", "fieldtype": "Int", "label": "Total Operators", "read_only": 1},
    {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "read_only": 1},
    {"fieldname": "section_records", "fieldtype": "Section Break", "label": "Payment Records"},
    {"fieldname": "payment_records", "fieldtype": "Table", "label": "Payment Records", "options": "Payment Record"},
    {"fieldname": "approved_by", "fieldtype": "Link", "label": "Approved By", "options": "User", "read_only": 1},
    {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
  ],
  "title_field": "batch_name",
  "autoname": "naming_series:",
  "naming_series": "PAY-.YYYY.-",
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "All", "read": 1}
  ]
}
