{
  "name": "Daily Attendance",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "fields": [
    {"fieldname": "project", "fieldtype": "Link", "label": "Project", "options": "QAIFF Project", "reqd": 1, "in_list_view": 1},
    {"fieldname": "operator", "fieldtype": "Link", "label": "Operator", "options": "Operator Profile", "reqd": 1, "in_list_view": 1},
    {"fieldname": "full_name", "fieldtype": "Data", "label": "Full Name", "fetch_from": "operator.full_name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "attendance_date", "fieldtype": "Date", "label": "Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "shift", "fieldtype": "Select", "label": "Shift", "options": "A\nB", "default": "A", "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Present\nAbsent\nHalf Day", "default": "Present", "reqd": 1, "in_list_view": 1},
    {"fieldname": "section_approval", "fieldtype": "Section Break", "label": "Approval"},
    {"fieldname": "approved_by", "fieldtype": "Link", "label": "Approved By", "options": "User", "read_only": 1},
    {"fieldname": "approved_on", "fieldtype": "Datetime", "label": "Approved On", "read_only": 1},
    {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Remarks"}
  ],
  "title_field": "full_name",
  "search_fields": "full_name,project,attendance_date",
  "autoname": "naming_series:",
  "naming_series": "ATT-.YYYY.MM.-",
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "All", "read": 1, "write": 1, "create": 1}
  ]
}
