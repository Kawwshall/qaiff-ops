{
  "name": "Factory",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "fields": [
    {"fieldname": "factory_name", "fieldtype": "Data", "label": "Factory Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "factory_code", "fieldtype": "Data", "label": "Factory Code", "reqd": 1, "in_list_view": 1, "description": "Short code e.g. TS, MH, RJ"},
    {"fieldname": "city", "fieldtype": "Data", "label": "City", "in_list_view": 1},
    {"fieldname": "state", "fieldtype": "Data", "label": "State"},
    {"fieldname": "address", "fieldtype": "Small Text", "label": "Address"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Active\nInactive", "default": "Active"}
  ],
  "title_field": "factory_name",
  "search_fields": "factory_name,factory_code,city",
  "autoname": "field:factory_code",
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "All", "read": 1}
  ]
}
