{
  "name": "QAIFF Project",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "fields": [
    {"fieldname": "project_name", "fieldtype": "Data", "label": "Project Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "factory", "fieldtype": "Link", "label": "Factory", "options": "Factory", "reqd": 1, "in_list_view": 1},
    {"fieldname": "city", "fieldtype": "Data", "label": "City", "fetch_from": "factory.city", "read_only": 1},
    {"fieldname": "start_date", "fieldtype": "Date", "label": "Start Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "end_date", "fieldtype": "Date", "label": "End Date"},
    {"fieldname": "shift", "fieldtype": "Select", "label": "Shift", "options": "A\nB\nBoth", "default": "A"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Planning\nActive\nCompleted\nCancelled", "default": "Planning", "in_list_view": 1},
    {"fieldname": "section_roster", "fieldtype": "Section Break", "label": "Roster"},
    {"fieldname": "roster", "fieldtype": "Table", "label": "Roster", "options": "Project Roster Entry"},
    {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
  ],
  "title_field": "project_name",
  "search_fields": "project_name,factory",
  "autoname": "naming_series:",
  "naming_series": "PROJ-.YYYY.-",
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "All", "read": 1}
  ]
}
