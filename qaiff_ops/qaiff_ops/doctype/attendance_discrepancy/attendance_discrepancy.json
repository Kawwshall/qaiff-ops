{
  "name": "Attendance Discrepancy",
  "doctype": "DocType",
  "module": "QAIFF Ops",
  "engine": "InnoDB",
  "autoname": "format:DISC-{####}",
  "title_field": "operator_name",
  "search_fields": "operator_name,project",
  "fields": [
    {"fieldname": "operator", "fieldtype": "Link", "label": "Operator", "options": "Operator", "reqd": 1, "in_list_view": 1},
    {"fieldname": "operator_name", "fieldtype": "Data", "label": "Name", "fetch_from": "operator.full_name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "project", "fieldtype": "Link", "label": "Project", "options": "FF Project", "reqd": 1, "in_list_view": 1},
    {"fieldname": "attendance_date", "fieldtype": "Date", "label": "Date in Question", "reqd": 1, "in_list_view": 1},
    {"fieldname": "claimed_status", "fieldtype": "Select", "label": "I was", "options": "Present\nHalf Day", "reqd": 1},
    {"fieldname": "reason", "fieldtype": "Small Text", "label": "Reason", "reqd": 1},
    {"fieldname": "sec_resolution", "fieldtype": "Section Break", "label": "Resolution"},
    {"fieldname": "resolution_status", "fieldtype": "Select", "label": "Status", "options": "Pending\nApproved\nRejected", "default": "Pending", "in_list_view": 1},
    {"fieldname": "resolved_by", "fieldtype": "Data", "label": "Resolved By"},
    {"fieldname": "resolution_note", "fieldtype": "Small Text", "label": "Resolution Note"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
    {"role": "FF Chief", "read": 1, "write": 1, "create": 0, "delete": 0, "report": 1},
    {"role": "FF Operator", "read": 1, "write": 0, "create": 1, "delete": 0, "if_owner": 1}
  ]
}
